  "type": "module",
  "main": "script.js",
  "scripts": {
    "start": "webpack serve --mode development",
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:gh-pages": "webpack --mode production --env GITHUB_PAGES=true",
    "predeploy": "npm run build:gh-pages",
    "deploy": "gh-pages -d dist",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.{js,ts,tsx}",
    "lint:fix": "eslint src/**/*.{js,ts,tsx} --fix",
    "format": "prettier --write src/**/*.{js,ts,tsx,css,html}",
    "prepare": "husky",
    "precommit": "lint-staged"
  },
  "lint-staged": {
    "src/**/*.{js,ts,css,html}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ],
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "git add"
    ],
    "src/**/*.{js,ts,tsx}": [
      "jest --findRelatedTests --bail",
      "git add"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
