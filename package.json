    "core-js": "^3.47.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "gh-pages": "^6.3.0",
    "html-webpack-plugin": "^5.6.5",
    "husky": "^9.1.7",
